{
  "name": "symphony",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "bun build src/cli/index.ts --outdir dist",
    "start": "bun --env-file=.env run src/cli/index.ts",
    "dev": "bun --watch src/cli/index.ts",
    "test": "bun test",
    "deploy:prepare": "./scripts/install.sh",
    "deploy:service": "sudo cp scripts/symphony.service /etc/systemd/system/ && sudo systemctl daemon-reload",
    "backup": "./scripts/symphony-cli.sh backup"
  },
  "bin": {
    "symphony": "./scripts/symphony-cli.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.8.0",
    "hono": "^4.12.12",
    "liquidjs": "^10.11.0",
    "uuid": "^9.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0"
  }
}
