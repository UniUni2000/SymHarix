{
  "name": "symharix",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "setup": "bun install && (test -f .env || cp .env.example .env) && (test -f WORKFLOW.md || cp WORKFLOW.md.example WORKFLOW.md)",
    "start": "bun run setup && bun --env-file=.env run src/cli/startLocal.ts",
    "stop": "bun --env-file=.env run src/cli/index.ts --kill",
    "health": "curl -fsS http://localhost:${PORT:-3000}/api/v1/runtime/manifest && echo && curl -fsS http://localhost:${PORT:-3000}/api/v1/bots/manifest",
    "test": "bun test",
    "build": "bun build --target bun src/cli/index.ts --outdir dist"
  },
  "bin": {
    "symharix": "./scripts/symharix-cli.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@resvg/resvg-js": "^2.6.2",
    "chokidar": "^3.6.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.8.0",
    "hono": "^4.12.12",
    "liquidjs": "^10.11.0",
    "uuid": "^9.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0"
  }
}
