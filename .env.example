# symphonyness local configuration example
#
# `bun run setup:local` copies this file to `.env` only when `.env` does not
# already exist. Fill `.env` for your machine and never commit it.
#
# Fast path:
#
#   bun run setup:local
#   # edit .env and WORKFLOW.md
#   bun run start:local
#
# Minimum local execution usually needs these values:
#
#   SYMPHONY_TRACKER_API_KEY
#   SYMPHONY_TRACKER_PROJECT_SLUG
#   GITHUB_TOKEN
#   ANTHROPIC_API_KEY
#
# Optional integrations such as Telegram and Discord are blank by default so a
# fresh copy does not accidentally call external APIs with placeholder tokens.

# ---------------------------------------------------------
# Required: Linear / tracker
# ---------------------------------------------------------
# Only `linear` is currently supported.
SYMPHONY_TRACKER_KIND=linear

# Linear API key used by the TypeScript control plane and Python hooks.
SYMPHONY_TRACKER_API_KEY=your-linear-api-key

# Default Linear project slug used by Telegram/runtime issue creation.
# This must match a key under WORKFLOW.md -> repositories.routing.
SYMPHONY_TRACKER_PROJECT_SLUG=sample-project

# Legacy Python hook compatibility. Prefer SYMPHONY_TRACKER_API_KEY.
# LINEAR_API_KEY=

# ---------------------------------------------------------
# Required: GitHub
# ---------------------------------------------------------
# Required by Python dispatch/dev/review hooks and used by TypeScript GitHub
# clients. Use a token with access to the target repositories in WORKFLOW.md.
GITHUB_TOKEN=your-github-token

# Optional fallback owner/repo for older Python paths. The main path should use
# WORKFLOW.md -> repositories.routing instead of these fallbacks.
GITHUB_OWNER=
GITHUB_REPO=

# Internal route bridge variables. Orchestrator normally injects these for
# Python hooks; set manually only when running scripts/cli.py standalone.
# SYMPHONY_GITHUB_REPO_FULL=owner/repo
# SYMPHONY_GITHUB_OWNER=owner
# SYMPHONY_GITHUB_REPO=repo

# ---------------------------------------------------------
# Required: Claude Code runtime / agent
# ---------------------------------------------------------
# Used by the default adapter/runtime and as a fallback for supervisor LLM code.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional Anthropic fallback settings for older supervisor paths.
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=

# Recommended local Claude Code runtime settings.
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_LOCAL_SKIP_REMOTE_PREFETCH=1

# Adapter/runner diagnostics. Set to 1 only when debugging agent I/O.
SYMPHONY_ADAPTER_DEBUG=

# ---------------------------------------------------------
# Runtime write access
# ---------------------------------------------------------
# Blank means local open mode. Set this before exposing /runtime or runtime API
# through a public URL/tunnel.
SYMPHONY_RUNTIME_WRITE_TOKEN=

# ---------------------------------------------------------
# Optional: Telegram product surface
# ---------------------------------------------------------
# Leave blank to disable Telegram. When set, /api/v1/bots/telegram/webhook is
# enabled and start:local may try to prepare a public tunnel if no public URL is
# configured.
SYMPHONY_TELEGRAM_BOT_TOKEN=
SYMPHONY_TELEGRAM_WEBHOOK_SECRET=

# Comma-separated Telegram user ids allowed to run write actions. Blank means
# no operator-id restriction.
SYMPHONY_TELEGRAM_OPERATOR_IDS=

# Optional fixed operations chat. If omitted, only origin/watch chats receive
# proactive follow-ups.
SYMPHONY_TELEGRAM_OPERATIONS_CHAT_ID=

# Existing public HTTPS base URL for Telegram webhook and Mini App links.
# If blank and Telegram is enabled, bootstrap may create a temporary tunnel.
SYMPHONY_PUBLIC_BASE_URL=

# off = do not set Telegram webhook automatically. Blank = auto.
SYMPHONY_TELEGRAM_BOOTSTRAP=

# Tunnel command/protocol for Telegram auto-bootstrap.
SYMPHONY_TELEGRAM_TUNNEL_COMMAND=
SYMPHONY_TELEGRAM_TUNNEL_PROTOCOL=http2

# Telegram text ACK delay. Default in code: 3000.
SYMPHONY_TELEGRAM_TEXT_ACK_DELAY_MS=3000

# Telegram API networking. start:local can auto-detect local proxies; use these
# only when your Telegram API access needs explicit control.
SYMPHONY_PROXY_MODE=auto
SYMPHONY_PROXY_URL=
SYMPHONY_TELEGRAM_DISABLE_PROXY=
SYMPHONY_TELEGRAM_CURL_TIMEOUT_SECONDS=

# start:local Telegram bootstrap retry/startup summary tuning.
SYMPHONY_TELEGRAM_WEBHOOK_RETRY_ATTEMPTS=6
SYMPHONY_TELEGRAM_WEBHOOK_RETRY_DELAY_MS=2000
SYMPHONY_TELEGRAM_STARTUP_SUMMARY_ATTEMPTS=60

# ---------------------------------------------------------
# Optional: Bot natural-language LLM
# ---------------------------------------------------------
# Leave blank to use deterministic parsing/fallback. Configure this when you
# want richer Telegram/Discord natural-language behavior.
# Supported providers: anthropic, openai.
SYMPHONY_BOT_LLM_PROVIDER=
SYMPHONY_BOT_LLM_MODEL=
SYMPHONY_BOT_LLM_API_KEY=
SYMPHONY_BOT_LLM_BASE_URL=
SYMPHONY_BOT_LLM_TIMEOUT_MS=15000

# fetch | curl | auto. `auto` tries curl then fetch and can double worst-case
# latency; use `fetch` for normal operation.
SYMPHONY_BOT_LLM_HTTP_TRANSPORT=fetch

# Example Anthropic bot LLM:
# SYMPHONY_BOT_LLM_PROVIDER=anthropic
# SYMPHONY_BOT_LLM_MODEL=claude-3-5-sonnet-latest
# SYMPHONY_BOT_LLM_API_KEY=your-bot-llm-api-key

# ---------------------------------------------------------
# Optional: Supervisor planning brain
# ---------------------------------------------------------
# Defaults to SYMPHONY_BOT_LLM_* when configured. Leave blank for deterministic
# planning plus repo/governance rules.
SYMPHONY_SUPERVISOR_LLM_PROVIDER=
SYMPHONY_SUPERVISOR_LLM_MODEL=
SYMPHONY_SUPERVISOR_LLM_API_KEY=
SYMPHONY_SUPERVISOR_LLM_BASE_URL=
SYMPHONY_SUPERVISOR_LLM_TIMEOUT_MS=45000

# Optional: read-only Claude Code advisor for per-turn repo/code/artifact questions.
# Defaults to node scripts/claude-adapter.cjs through the repo-understanding command.
SYMPHONY_SUPERVISOR_READONLY_ADVISOR_COMMAND=
SYMPHONY_SUPERVISOR_READONLY_ADVISOR_TIMEOUT_MS=120000

# ---------------------------------------------------------
# Optional: Supervisor execution overseer
# ---------------------------------------------------------
# Defaults to supervisor LLM settings, then bot LLM settings, then deterministic
# oversight behavior.
SYMPHONY_SUPERVISOR_OVERSEER_PROVIDER=
SYMPHONY_SUPERVISOR_OVERSEER_MODEL=
SYMPHONY_SUPERVISOR_OVERSEER_API_KEY=
SYMPHONY_SUPERVISOR_OVERSEER_BASE_URL=
SYMPHONY_SUPERVISOR_OVERSEER_TIMEOUT_MS=30000

# ---------------------------------------------------------
# Startup repair / cleanup pacing
# ---------------------------------------------------------
# Supervisor job loop interval. Default in code: 30000.
SYMPHONY_SUPERVISOR_JOB_INTERVAL_MS=30000

# Cancel stale pre-materialization supervisor sessions during startup repair
# after this age. Default in docs/example: 1 day.
SYMPHONY_SUPERVISOR_SESSION_REPAIR_MAX_AGE_MS=86400000

# Delay bot follow-up repair so startup becomes responsive before history/card
# cleanup. Default in code: 5000.
SYMPHONY_BOT_FOLLOWUP_REPAIR_DELAY_MS=5000

# Delay terminal workspace/GitHub orphan cleanup so live E2E/dev/review is not
# competing with repair. Default in code: 900000.
SYMPHONY_STARTUP_CLEANUP_DELAY_MS=900000

# Delay first orchestrator poll so Telegram/session repair can settle first.
# Default in code: 10000.
SYMPHONY_FIRST_TICK_DELAY_MS=10000

# ---------------------------------------------------------
# Optional: Python hook compatibility / standalone script runs
# ---------------------------------------------------------
# The main Orchestrator path passes explicit workspace paths to Python hooks.
# These are useful mainly when running scripts/cli.py manually.
WORKSPACE_ROOT=
SYMPHONY_WORKSPACE_ROOT=

# Auto-merge PR even if no reviews are received. Default: false.
SYMPHONY_AUTO_MERGE_NO_REVIEWS=

# Orchestrator passes this to review hook when an effective harness is resolved.
# Set manually only for isolated hook debugging.
SYMPHONY_EFFECTIVE_HARNESS_JSON=

# ---------------------------------------------------------
# Optional: Discord thin adapter
# ---------------------------------------------------------
# Leave blank to disable Discord.
SYMPHONY_DISCORD_BOT_TOKEN=
SYMPHONY_DISCORD_PUBLIC_KEY=
SYMPHONY_DISCORD_OPERATOR_IDS=
