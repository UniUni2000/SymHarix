# symphonyness local configuration example
# symphonyness 本地配置示例
#
# `bun run setup:local` copies this file to `.env` only when `.env` does not exist.
# `bun run setup:local` 只会在 `.env` 不存在时复制本文件。
#
# Fast path / 最短路径:
#
#   bun run setup:local
#   # edit .env and WORKFLOW.md / 编辑 .env 和 WORKFLOW.md
#   bun run start:local
#
# Never commit `.env`.
# 不要提交 `.env`。

# ---------------------------------------------------------
# Required: tracker / 必填：tracker
# ---------------------------------------------------------
# Only `linear` is currently supported.
# 当前只支持 `linear`。
SYMPHONY_TRACKER_KIND=linear

# Linear API key for the TypeScript control plane and Python hooks.
# TypeScript 控制平面和 Python hooks 使用的 Linear API key。
SYMPHONY_TRACKER_API_KEY=your-linear-api-key

# Default Linear project slug for Telegram/Runtime issue creation.
# Must match WORKFLOW.md -> repositories.routing.
# Telegram/Runtime 创建 issue 时使用的默认 Linear project slug。
# 必须匹配 WORKFLOW.md -> repositories.routing。
SYMPHONY_TRACKER_PROJECT_SLUG=sample-project

# Legacy Python hook compatibility. Prefer SYMPHONY_TRACKER_API_KEY.
# 旧 Python hook 兼容项。优先使用 SYMPHONY_TRACKER_API_KEY。
# LINEAR_API_KEY=

# ---------------------------------------------------------
# Required: GitHub / 必填：GitHub
# ---------------------------------------------------------
# Token with access to the target repositories in WORKFLOW.md.
# 需要能访问 WORKFLOW.md 中目标仓库的 token。
GITHUB_TOKEN=your-github-token

# Optional fallback owner/repo for older Python paths.
# Main routing should use WORKFLOW.md -> repositories.routing.
# 旧 Python 路径的可选 fallback。主路径应使用 WORKFLOW.md -> repositories.routing。
GITHUB_OWNER=
GITHUB_REPO=

# Internal route bridge variables. The Orchestrator normally injects these.
# Set manually only when running scripts/cli.py standalone.
# 内部路由桥接变量。通常由 Orchestrator 注入。
# 只有单独运行 scripts/cli.py 时才需要手动设置。
# SYMPHONY_GITHUB_REPO_FULL=owner/repo
# SYMPHONY_GITHUB_OWNER=owner
# SYMPHONY_GITHUB_REPO=repo

# ---------------------------------------------------------
# Required: Claude Code-compatible runtime / 必填：Claude Code 兼容 runtime
# ---------------------------------------------------------
# Used by the bundled runtime and as a fallback for older supervisor paths.
# 内置 runtime 使用，也作为旧 supervisor 路径的 fallback。
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional Anthropic fallback settings for older paths.
# 旧路径的可选 Anthropic fallback。
ANTHROPIC_MODEL=
ANTHROPIC_BASE_URL=

# Recommended local runtime settings.
# 推荐的本地 runtime 设置。
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_LOCAL_SKIP_REMOTE_PREFETCH=1

# Adapter defaults. Usually do not override.
# adapter 默认值，通常不需要覆盖。
# CLAUDE_CODE_SIMPLE=1
# CLAUDE_CODE_GLOB_HIDDEN=false
# CLAUDE_CODE_DISABLE_AUTO_MEMORY=1
# CLAUDE_CODE_DISABLE_BACKGROUND_TASKS=1
# CLAUDE_CODE_READ_ONLY=0

# Set to 1 only when debugging agent I/O.
# 只在调试 agent I/O 时设置为 1。
SYMPHONY_ADAPTER_DEBUG=

# ---------------------------------------------------------
# Runtime Deck write protection / Runtime Deck 写保护
# ---------------------------------------------------------
# Blank means local open mode. Set before exposing /runtime publicly.
# 留空表示本地开放模式。公开暴露 /runtime 前请设置。
SYMPHONY_RUNTIME_WRITE_TOKEN=

# ---------------------------------------------------------
# Telegram product surface / Telegram 产品入口
# ---------------------------------------------------------
# Leave token blank to disable Telegram.
# token 留空则禁用 Telegram。
SYMPHONY_TELEGRAM_BOT_TOKEN=
SYMPHONY_TELEGRAM_WEBHOOK_SECRET=

# Comma-separated Telegram user ids allowed to run write actions.
# Blank means no operator-id restriction.
# 允许执行写操作的 Telegram user id，逗号分隔。
# 留空表示不限制 operator id。
SYMPHONY_TELEGRAM_OPERATOR_IDS=

# Optional fixed operations chat. If omitted, only origin/watch chats receive proactive follow-ups.
# 可选固定 operations chat。留空时，只有来源 chat 或 watch chat 会收到主动 follow-up。
SYMPHONY_TELEGRAM_OPERATIONS_CHAT_ID=

# Public HTTPS base URL for Telegram webhook and Mini App links.
# If blank and Telegram is enabled, start:local may create a temporary tunnel.
# Telegram webhook 和 Mini App 链接使用的公网 HTTPS base URL。
# 留空且启用 Telegram 时，start:local 可能创建临时隧道。
SYMPHONY_PUBLIC_BASE_URL=

# off = do not register Telegram webhook automatically. Blank = auto.
# off 表示不自动注册 Telegram webhook。留空表示自动。
SYMPHONY_TELEGRAM_BOOTSTRAP=

# Local tunnel settings used by start:local.
# start:local 使用的本地隧道设置。
SYMPHONY_TELEGRAM_TUNNEL_COMMAND=
SYMPHONY_TELEGRAM_TUNNEL_PROTOCOL=http2
SYMPHONY_TELEGRAM_TUNNEL_RETRY_ATTEMPTS=3
SYMPHONY_TELEGRAM_TUNNEL_RETRY_DELAY_MS=1500
SYMPHONY_TELEGRAM_TUNNEL_WATCHDOG_INTERVAL_MS=10000
SYMPHONY_TELEGRAM_TUNNEL_WATCHDOG_DEGRADED_POLLS=2

# Telegram acknowledgement and text coalescing.
# Telegram 确认消息和文本合并。
SYMPHONY_TELEGRAM_TEXT_ACK_DELAY_MS=3000
SYMPHONY_TELEGRAM_TEXT_COALESCE_DELAY_MS=

# Telegram API networking. start:local can auto-detect common local proxies.
# Telegram API 网络设置。start:local 可以自动检测常见本地代理。
SYMPHONY_PROXY_MODE=auto
SYMPHONY_PROXY_URL=
SYMPHONY_TELEGRAM_DISABLE_PROXY=
SYMPHONY_TELEGRAM_CURL_TIMEOUT_SECONDS=

# Telegram webhook retry and startup summary.
# Telegram webhook 重试和启动摘要参数。
SYMPHONY_TELEGRAM_WEBHOOK_RETRY_ATTEMPTS=6
SYMPHONY_TELEGRAM_WEBHOOK_RETRY_DELAY_MS=2000
SYMPHONY_TELEGRAM_STARTUP_SUMMARY_ATTEMPTS=60

# ---------------------------------------------------------
# Bot natural-language LLM / Bot 自然语言 LLM
# ---------------------------------------------------------
# Leave blank to use deterministic parsing/fallback.
# Configure this for richer Telegram/Discord natural-language behavior.
# 留空则使用确定性解析和 fallback。
# 配置后 Telegram/Discord 自然语言能力更强。
# Supported providers / 支持 provider: anthropic, openai.
SYMPHONY_BOT_LLM_PROVIDER=
SYMPHONY_BOT_LLM_MODEL=
SYMPHONY_BOT_LLM_API_KEY=
SYMPHONY_BOT_LLM_BASE_URL=
SYMPHONY_BOT_LLM_TIMEOUT_MS=15000

# fetch | curl | auto. Use fetch for normal operation.
# `auto` tries multiple clients and can increase worst-case latency.
# fetch | curl | auto。日常使用 fetch。
# `auto` 会尝试多个 client，最坏延迟可能更高。
SYMPHONY_BOT_LLM_HTTP_TRANSPORT=fetch

# Example / 示例:
# SYMPHONY_BOT_LLM_PROVIDER=anthropic
# SYMPHONY_BOT_LLM_MODEL=claude-3-5-sonnet-latest
# SYMPHONY_BOT_LLM_API_KEY=your-bot-llm-api-key

# ---------------------------------------------------------
# Supervisor brains / Supervisor 模型
# ---------------------------------------------------------
# Planning defaults to SYMPHONY_BOT_LLM_*.
# 计划模型默认复用 SYMPHONY_BOT_LLM_*。
SYMPHONY_SUPERVISOR_LLM_PROVIDER=
SYMPHONY_SUPERVISOR_LLM_MODEL=
SYMPHONY_SUPERVISOR_LLM_API_KEY=
SYMPHONY_SUPERVISOR_LLM_BASE_URL=
SYMPHONY_SUPERVISOR_LLM_TIMEOUT_MS=45000

# Top-level Supervisor assistant model.
# Fallback order: AGENT_* -> CC_* -> SUPERVISOR_LLM_* -> BOT_LLM_*.
# 顶层 Supervisor 助手模型。
# 回退顺序：AGENT_* -> CC_* -> SUPERVISOR_LLM_* -> BOT_LLM_*。
SYMPHONY_SUPERVISOR_AGENT_PROVIDER=
SYMPHONY_SUPERVISOR_AGENT_MODEL=
SYMPHONY_SUPERVISOR_AGENT_API_KEY=
SYMPHONY_SUPERVISOR_AGENT_BASE_URL=
SYMPHONY_SUPERVISOR_AGENT_TIMEOUT_MS=45000

# Compatibility layer for the older Supervisor CC advisor.
# 旧 Supervisor CC advisor 的兼容配置层。
SYMPHONY_SUPERVISOR_CC_PROVIDER=
SYMPHONY_SUPERVISOR_CC_MODEL=
SYMPHONY_SUPERVISOR_CC_API_KEY=
SYMPHONY_SUPERVISOR_CC_BASE_URL=
SYMPHONY_SUPERVISOR_CC_TIMEOUT_MS=45000

# Telegram Supervisor Claude runtime front door.
# Set runtime to off only when intentionally disabling it.
# Telegram Supervisor Claude runtime 前门。
# 只有明确要禁用时才设置为 off。
SYMPHONY_SUPERVISOR_CLAUDE_RUNTIME=
SYMPHONY_SUPERVISOR_CLAUDE_COMMAND=

# Read-only repo understanding and per-turn repo advisor.
# Blank values use node scripts/claude-adapter.cjs.
# 只读仓库理解和每轮仓库顾问。
# 留空时使用 node scripts/claude-adapter.cjs。
SYMPHONY_SUPERVISOR_REPO_UNDERSTANDING_COMMAND=
SYMPHONY_SUPERVISOR_REPO_UNDERSTANDING_TIMEOUT_MS=120000
SYMPHONY_SUPERVISOR_READONLY_ADVISOR_COMMAND=
SYMPHONY_SUPERVISOR_READONLY_ADVISOR_TIMEOUT_MS=120000

# Execution overseer. Falls back to supervisor/bot LLM, then deterministic oversight.
# 执行监督模型。失败时回退到 supervisor/bot LLM，再回退到确定性监督。
SYMPHONY_SUPERVISOR_OVERSEER_PROVIDER=
SYMPHONY_SUPERVISOR_OVERSEER_MODEL=
SYMPHONY_SUPERVISOR_OVERSEER_API_KEY=
SYMPHONY_SUPERVISOR_OVERSEER_BASE_URL=
SYMPHONY_SUPERVISOR_OVERSEER_TIMEOUT_MS=30000

# ---------------------------------------------------------
# Startup repair and cleanup pacing / 启动修复和清理节奏
# ---------------------------------------------------------
SYMPHONY_SUPERVISOR_JOB_INTERVAL_MS=30000
SYMPHONY_SUPERVISOR_SESSION_REPAIR_MAX_AGE_MS=86400000
SYMPHONY_BOT_FOLLOWUP_REPAIR_DELAY_MS=5000
SYMPHONY_STARTUP_CLEANUP_DELAY_MS=900000
SYMPHONY_FIRST_TICK_DELAY_MS=10000

# ---------------------------------------------------------
# Standalone Python hook compatibility / 独立 Python hook 兼容
# ---------------------------------------------------------
# Main Orchestrator passes explicit workspace paths to Python hooks.
# These are mainly for manual scripts/cli.py runs.
# 主 Orchestrator 会把 workspace path 显式传给 Python hooks。
# 这些变量主要用于手动运行 scripts/cli.py。
WORKSPACE_ROOT=
SYMPHONY_WORKSPACE_ROOT=

# Auto-merge PR even if no reviews are received. Default: false.
# 即使没有 review 也自动 merge PR。默认 false。
SYMPHONY_AUTO_MERGE_NO_REVIEWS=

# Orchestrator passes this to review hook when an effective harness is resolved.
# Set manually only for isolated hook debugging.
# Orchestrator 解析到 effective harness 后会传给 review hook。
# 只有隔离调试 hook 时才手动设置。
SYMPHONY_EFFECTIVE_HARNESS_JSON=

# ---------------------------------------------------------
# Discord thin adapter / Discord 轻量适配层
# ---------------------------------------------------------
# Leave blank to disable Discord.
# 留空则禁用 Discord。
SYMPHONY_DISCORD_BOT_TOKEN=
SYMPHONY_DISCORD_PUBLIC_KEY=
SYMPHONY_DISCORD_OPERATOR_IDS=
