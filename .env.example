# Symphony Configuration
#
# Copy this file to `.env` and fill the values for your local machine:
#
#   cp .env.example .env
#
# Do not commit `.env`.

# ---------------------------------------------------------
# Linear / tracker
# ---------------------------------------------------------
SYMPHONY_TRACKER_KIND=linear
SYMPHONY_TRACKER_API_KEY=your-linear-api-key
# Default project used by Telegram/runtime issue creation.
# Example:
#   SYMPHONY_TRACKER_PROJECT_SLUG=sample-project
SYMPHONY_TRACKER_PROJECT_SLUG=your-linear-project-slug

# ---------------------------------------------------------
# Claude Code runtime
# ---------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
CLAUDE_CODE_LOCAL_SKIP_REMOTE_PREFETCH=1

# ---------------------------------------------------------
# Runtime write access
# ---------------------------------------------------------
# Optional: protect runtime write actions behind a shared token.
SYMPHONY_RUNTIME_WRITE_TOKEN=your-runtime-write-token

# ---------------------------------------------------------
# Telegram
# ---------------------------------------------------------
# Optional: Telegram thin adapter.
SYMPHONY_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
SYMPHONY_TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret
# Comma-separated Telegram user ids allowed to run write actions.
SYMPHONY_TELEGRAM_OPERATOR_IDS=123456789,987654321
# Optional fixed operations chat. If omitted, only origin/watch chats receive proactive follow-ups.
SYMPHONY_TELEGRAM_OPERATIONS_CHAT_ID=123456789
# Optional: use an existing public URL for Telegram webhook bootstrap
SYMPHONY_PUBLIC_BASE_URL=
# Optional: disable Telegram webhook bootstrap entirely (`off`) or leave empty for auto
SYMPHONY_TELEGRAM_BOOTSTRAP=
# Optional: override the tunnel binary used for Telegram auto-bootstrap (default: cloudflared)
SYMPHONY_TELEGRAM_TUNNEL_COMMAND=
# Optional: cloudflared tunnel protocol for Telegram auto-bootstrap (default: http2; use quic only if your network supports it)
SYMPHONY_TELEGRAM_TUNNEL_PROTOCOL=http2

# ---------------------------------------------------------
# Bot natural-language LLM
# ---------------------------------------------------------
# Optional: dedicated bot LLM for natural-language Telegram/Discord assistant.
# Supported providers: anthropic, openai
SYMPHONY_BOT_LLM_PROVIDER=anthropic
SYMPHONY_BOT_LLM_MODEL=claude-3-5-sonnet-latest
SYMPHONY_BOT_LLM_API_KEY=your-bot-llm-api-key
# Optional for self-hosted / OpenAI-compatible endpoints
SYMPHONY_BOT_LLM_BASE_URL=
# Bound Telegram natural-language latency. Explicit write paths use local supervisor rules first.
SYMPHONY_BOT_LLM_TIMEOUT_MS=15000
# fetch | curl | auto. `auto` enables curl -> fetch transport fallback and can double worst-case latency.
SYMPHONY_BOT_LLM_HTTP_TRANSPORT=fetch

# ---------------------------------------------------------
# Supervisor planning brain
# ---------------------------------------------------------
# Optional: override the Telegram supervisor planning brain. Defaults to SYMPHONY_BOT_LLM_*.
SYMPHONY_SUPERVISOR_LLM_PROVIDER=
SYMPHONY_SUPERVISOR_LLM_MODEL=
SYMPHONY_SUPERVISOR_LLM_API_KEY=
SYMPHONY_SUPERVISOR_LLM_BASE_URL=
SYMPHONY_SUPERVISOR_LLM_TIMEOUT_MS=45000

# ---------------------------------------------------------
# Supervisor execution overseer
# ---------------------------------------------------------
# Optional: override the execution overseer brain. Defaults to SYMPHONY_SUPERVISOR_LLM_* then SYMPHONY_BOT_LLM_*.
SYMPHONY_SUPERVISOR_OVERSEER_PROVIDER=
SYMPHONY_SUPERVISOR_OVERSEER_MODEL=
SYMPHONY_SUPERVISOR_OVERSEER_API_KEY=
SYMPHONY_SUPERVISOR_OVERSEER_BASE_URL=
SYMPHONY_SUPERVISOR_OVERSEER_TIMEOUT_MS=30000

# ---------------------------------------------------------
# Startup repair / cleanup pacing
# ---------------------------------------------------------
# Optional: how often the recoverable supervisor job loop replays active sessions and writes memory.
SYMPHONY_SUPERVISOR_JOB_INTERVAL_MS=30000
# Optional: cancel stale pre-materialization supervisor sessions during startup repair after this age.
SYMPHONY_SUPERVISOR_SESSION_REPAIR_MAX_AGE_MS=86400000
# Optional: delay startup bot follow-up repair so bun run start becomes responsive before history cleanup.
SYMPHONY_BOT_FOLLOWUP_REPAIR_DELAY_MS=5000
# Optional: delay terminal workspace/GitHub orphan cleanup so live E2E/dev/review is not competing with repair.
SYMPHONY_STARTUP_CLEANUP_DELAY_MS=900000

# ---------------------------------------------------------
# Discord
# ---------------------------------------------------------
# Optional: Discord thin adapter.
SYMPHONY_DISCORD_BOT_TOKEN=your-discord-bot-token
SYMPHONY_DISCORD_PUBLIC_KEY=your-discord-public-key
SYMPHONY_DISCORD_OPERATOR_IDS=111111111111111111,222222222222222222
